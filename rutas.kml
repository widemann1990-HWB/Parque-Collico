<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Parque Collico</title>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet-omnivore/leaflet-omnivore.min.js"></script>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, sans-serif;
}

body{
background:#111;
color:white;
}

/* PANTALLAS */
.pantalla{ display:none; }
.activa{ display:block; }

/* INICIO */
#inicio{
position:relative;
height:100vh;
}

#inicio img{
width:100%;
height:100vh;
object-fit:cover;
}

.overlay{
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,.4);
}

.logo{
position:absolute;
top:60px;
width:100%;
text-align:center;
font-size:34px;
font-weight:bold;
}

.subtitulo{
position:absolute;
bottom:120px;
width:100%;
text-align:center;
font-size:18px;
}

.boton{
position:absolute;
bottom:50px;
left:50%;
transform:translateX(-50%);
padding:15px 30px;
border:none;
border-radius:30px;
background:#2c7a7b;
color:white;
font-size:18px;
}

/* REGISTRO */
#registro{
background:white;
color:black;
min-height:100vh;
padding:25px;
}

.form-card{
max-width:500px;
margin:auto;
}

input{
width:100%;
padding:12px;
margin-bottom:12px;
border-radius:10px;
border:1px solid #ccc;
}

.terminos{
height:150px;
overflow:auto;
background:#f3f3f3;
padding:10px;
border-radius:10px;
margin-bottom:10px;
font-size:13px;
}

.check{
display:flex;
gap:10px;
margin-bottom:15px;
}

.btn-entrar{
width:100%;
padding:15px;
background:#2c7a7b;
color:white;
border:none;
border-radius:10px;
}

/* MAPA */
#map{
height:100vh;
width:100%;
}

</style>
</head>
<body>

<!-- INICIO -->
<div id="inicio" class="pantalla activa">

<img src="img/foto1.jpg">
<div class="overlay"></div>

<div class="logo">PARQUE COLLICO</div>

<div class="subtitulo">
Trail Running · MTB · Trekking · Naturaleza
</div>

<button class="boton" onclick="mostrar('registro')">
INGRESAR
</button>

</div>

<!-- REGISTRO -->
<div id="registro" class="pantalla">

<div class="form-card">

<h2>Registro de Ingreso</h2>

<input id="nombre" placeholder="Nombre completo">
<input id="rut" placeholder="RUT">
<input id="telefono" placeholder="Teléfono">
<input id="correo" placeholder="Correo electrónico">

<div class="terminos">
El ingreso al Parque Collico implica la aceptación de estos términos.

Las actividades se realizan bajo responsabilidad del visitante.
Se prohíbe dañar flora y fauna.
No hacer fuego.
Mascotas bajo control.
</div>

<div class="check">
<input type="checkbox" id="acepta">
<label>Acepto términos</label>
</div>

<button class="btn-entrar" onclick="entrarMapa()">
ENTRAR AL PARQUE
</button>

</div>
</div>

<!-- MAPA -->
<div id="mapa" class="pantalla">
<div id="map"></div>
</div>

<script>

function mostrar(id){
document.querySelectorAll('.pantalla')
.forEach(p=>p.classList.remove('activa'));

document.getElementById(id).classList.add('activa');
}

function entrarMapa(){

let nombre=document.getElementById("nombre").value;
let rut=document.getElementById("rut").value;
let telefono=document.getElementById("telefono").value;
let correo=document.getElementById("correo").value;
let acepta=document.getElementById("acepta").checked;

if(!nombre || !rut || !telefono || !correo){
alert("Completa todos los campos");
return;
}

if(!acepta){
alert("Debes aceptar los términos");
return;
}

mostrar("mapa");
setTimeout(iniciarMapa,300);

}

function iniciarMapa(){

if(window.mapaCreado) return;
window.mapaCreado=true;

const map = L.map('map').setView([-39.82,-73.18],14);

L.tileLayer(
'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png'
).addTo(map);

// 🔥 CARGAR KML (USA COLORES DEL KML)
omnivore.kml('rutas.kml')
.on('ready', function(){

console.log("KML cargado correctamente");

// NO usamos setStyle → respeta colores del KML
map.fitBounds(this.getBounds());

})
.on('error', function(e){

console.log("ERROR KML:", e);

})
.addTo(map);

// 📍 UBICACIÓN
map.locate({ setView:true, maxZoom:16 });

map.on('locationfound', e => {

L.marker(e.latlng)
.addTo(map)
.bindPopup("Tu ubicación")
.openPopup();

});

}

</script>

</body>
</html>
